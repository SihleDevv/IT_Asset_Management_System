@model IT_Asset_Management_System.Models.Computer
@{
    ViewData["Title"] = "Delete Computer";
}

<h1>Delete Computer</h1>

<div class="alert alert-danger">
    <h3>Are you sure you want to delete this computer?</h3>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Asset Tag</dt>
            <dd class="col-sm-9">@Model.AssetTag</dd>

            <dt class="col-sm-3">Computer Name</dt>
            <dd class="col-sm-9">@Model.AssetName</dd>

            <dt class="col-sm-3">Brand/Model</dt>
            <dd class="col-sm-9">@Model.Brand @Model.Model</dd>

            <dt class="col-sm-3">Serial Number</dt>
            <dd class="col-sm-9">@Model.SerialNumber</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>