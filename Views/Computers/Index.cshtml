@model IEnumerable<IT_Asset_Management_System.Models.Computer>
@{
    ViewData["Title"] = "Computers";
}

<h1>Computers</h1>

@if (User.IsInRole("Admin") || User.IsInRole("IT Manager"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Create New Computer</a>
    </p>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Asset Tag</th>
                <th>Asset Name</th>
                <th>Brand/Model</th>
                <th>Serial Number</th>
                <th>RAM</th>
                <th>Storage</th>
                <th>Assigned To</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.AssetTag</td>
                    <td>@item.AssetName</td>
                    <td>@item.Brand @item.Model</td>
                    <td>@item.SerialNumber</td>
                    <td>@item.RAM GB</td>
                    <td>@item.Storage GB</td>
                    <td>@item.AssignedTo</td>
                    <td>
                        @if (item.Status == "Available")
                        {
                            <span class="badge bg-success">@item.Status</span>
                        }
                        else if (item.Status == "In Use")
                        {
                            <span class="badge bg-primary">@item.Status</span>
                        }
                        else if (item.Status == "Under Maintenance")
                        {
                            <span class="badge bg-warning">@item.Status</span>
                        }
                        else if (item.Status == "Retired" || item.Status == "Damaged")
                        {
                            <span class="badge bg-danger">@item.Status</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@item.Status</span>
                        }
                    </td>
                    <td>
                        <div class="d-flex gap-2 align-items-center">
                            <a asp-action="Details" asp-route-id="@item.Id" title="Details" style="text-decoration: none; color: #0dcaf0; font-size: 1.1rem;">
                                <i class="fas fa-eye"></i>
                            </a>
                            @if (User.IsInRole("Admin") || User.IsInRole("IT Manager"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" title="Edit" style="text-decoration: none; color: #ffc107; font-size: 1.1rem;">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" title="Delete" style="text-decoration: none; color: #dc3545; font-size: 1.1rem;">
                                    <i class="fas fa-trash"></i>
                                </a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
