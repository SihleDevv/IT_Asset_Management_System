@model IT_Asset_Management_System.Models.Computer
@{
    ViewData["Title"] = "Edit Computer";
}

<h1>Edit Computer</h1>
<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            
            <!-- Same form fields as Create.cshtml -->
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="AssetTag" class="control-label"></label>
                        <input asp-for="AssetTag" class="form-control" />
                        <span asp-validation-for="AssetTag" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="AssetName" class="control-label"></label>
                        <input asp-for="AssetName" class="form-control" />
                        <span asp-validation-for="AssetName" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Brand" class="control-label"></label>
                        <input asp-for="Brand" class="form-control" />
                        <span asp-validation-for="Brand" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Model" class="control-label"></label>
                        <input asp-for="Model" class="form-control" />
                        <span asp-validation-for="Model" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="SerialNumber" class="control-label"></label>
                <input asp-for="SerialNumber" class="form-control" />
                <span asp-validation-for="SerialNumber" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="Processor" class="control-label"></label>
                        <input asp-for="Processor" class="form-control" />
                        <span asp-validation-for="Processor" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="RAM" class="control-label">RAM (GB)</label>
                        <input asp-for="RAM" class="form-control" type="number" />
                        <span asp-validation-for="RAM" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group mb-3">
                        <label asp-for="Storage" class="control-label">Storage (GB)</label>
                        <input asp-for="Storage" class="form-control" type="number" />
                        <span asp-validation-for="Storage" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="OperatingSystem" class="control-label"></label>
                <select asp-for="OperatingSystem" class="form-control">
                    <option value="">-- Select Operating System --</option>
                    <option value="Windows 10">Windows 10</option>
                    <option value="Windows 11">Windows 11</option>
                    <option value="Windows Server 2019">Windows Server 2019</option>
                    <option value="Windows Server 2022">Windows Server 2022</option>
                    <option value="Linux Ubuntu">Linux Ubuntu</option>
                    <option value="Linux CentOS">Linux CentOS</option>
                    <option value="macOS">macOS</option>
                    <option value="Other">Other</option>
                </select>
                <span asp-validation-for="OperatingSystem" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="PurchaseDate" class="control-label"></label>
                        <input asp-for="PurchaseDate" class="form-control" type="date" />
                        <span asp-validation-for="PurchaseDate" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="PurchasePrice" class="control-label"></label>
                        <div class="input-group">
                            <span class="input-group-text">R</span>
                            <input asp-for="PurchasePrice" class="form-control" type="number" step="0.01" />
                        </div>
                        <span asp-validation-for="PurchasePrice" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Vendor" class="control-label"></label>
                        <select asp-for="Vendor" class="form-control">
                            <option value="">-- Select Vendor --</option>
                            <option value="Dell">Dell</option>
                            <option value="HP">HP</option>
                            <option value="Lenovo">Lenovo</option>
                            <option value="Microsoft">Microsoft</option>
                            <option value="Apple">Apple</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Vendor" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="WarrantyExpiryDate" class="control-label"></label>
                        <input asp-for="WarrantyExpiryDate" class="form-control" type="date" />
                        <span asp-validation-for="WarrantyExpiryDate" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="Location" class="control-label"></label>
                        <select asp-for="Location" class="form-control">
                            <option value="">-- Select Location --</option>
                            <option value="Sed1">Sed1</option>
                            <option value="Sed2">Sed2</option>
                            <option value="Sed3">Sed3</option>
                        </select>
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group mb-3">
                        <label asp-for="AssignedTo" class="control-label"></label>
                        <select asp-for="AssignedTo" class="form-control">
                            <option value="">-- Select User --</option>
                            <option value="Unassigned">Unassigned</option>
                            @{
                                var users = ViewBag.Users as List<IT_Asset_Management_System.Models.ApplicationUser> ?? new List<IT_Asset_Management_System.Models.ApplicationUser>();
                            }
                            @foreach (var user in users.Where(u => u.IsActive == true).OrderBy(u => u.FullName ?? u.UserName ?? u.Email))
                            {
                                var displayName = user.FullName ?? user.UserName ?? user.Email;
                                <option value="@displayName" selected="@(Model.AssignedTo == displayName)">@displayName</option>
                            }
                        </select>
                        <span asp-validation-for="AssignedTo" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-control">
                    <option value="Available">Available</option>
                    <option value="In Use">In Use</option>
                    <option value="Under Maintenance">Under Maintenance</option>
                    <option value="Retired">Retired</option>
                    <option value="Damaged">Damaged</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Notes" class="control-label"></label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Notes" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

}