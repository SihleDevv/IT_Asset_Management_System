@model IT_Asset_Management_System.Models.BaseAsset

@{
    var m = Model;
    ViewData["Title"] = "Delete Asset";
}

<div class="page-header">
    <h1>Delete Asset</h1>
</div>

<div class="alert alert-danger">
    <h4><i class="fas fa-exclamation-triangle"></i> Are you sure you want to delete this asset?</h4>
    <p>This action cannot be undone.</p>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Asset Tag</dt>
            <dd class="col-sm-9">@m?.AssetTag</dd>

            <dt class="col-sm-3">Asset Name</dt>
            <dd class="col-sm-9">@m?.AssetName</dd>

            <dt class="col-sm-3">Type</dt>
            <dd class="col-sm-9">@m?.AssetType</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@m?.Status</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">
        <i class="fas fa-trash"></i> Confirm Delete
    </button>
    <a asp-action="Index" asp-route-assetType="@m?.AssetType" class="btn btn-secondary">
        <i class="fas fa-times"></i> Cancel
    </a>
</form>
