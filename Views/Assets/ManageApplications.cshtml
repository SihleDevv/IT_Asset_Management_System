@{
    ViewData["Title"] = "Manage Server Applications";
    var server = ViewBag?.Server as IT_Asset_Management_System.Models.Server;
    var installedApps = ViewBag?.InstalledApplications as List<IT_Asset_Management_System.Models.ServerApplication> ?? new List<IT_Asset_Management_System.Models.ServerApplication>();
    var availableApps = ViewBag?.AvailableApplications as List<IT_Asset_Management_System.Models.Application> ?? new List<IT_Asset_Management_System.Models.Application>();
}

<div class="page-header">
    <h1>Manage Applications - @(server?.AssetName ?? "Server")</h1>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header"><h5><i class="fas fa-check-circle"></i> Installed Applications</h5></div>
            <div class="card-body">
                @if (installedApps.Any())
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Application</th>
                                <th>Version</th>
                                <th>Status</th>
                                <th>Installed By</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var app in installedApps)
                            {
                                <tr>
                                    <td>@(app?.Application?.AssetName ?? "—")</td>
                                    <td>@(app?.InstalledVersion ?? "—")</td>
                                    <td>
                                        @if (app?.Status == "Running")
                                        {
                                            <span class="badge bg-success">@app.Status</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">@app?.Status</span>
                                        }
                                    </td>
                                    <td>@(app?.CreatedBy ?? "—")</td>
                                    <td>
                                        <form asp-action="UninstallApplication" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to uninstall this application?');">
                                            <input type="hidden" name="id" value="@(app?.Id)" />
                                            <input type="hidden" name="serverId" value="@(server?.Id)" />
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-danger" title="Uninstall">
                                                <i class="fas fa-trash"></i> Uninstall
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">No applications installed.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header"><h5><i class="fas fa-plus-circle"></i> Install Application</h5></div>
            <div class="card-body">
                @if (availableApps.Any())
                {
                    <form asp-action="InstallApplication" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="serverId" value="@(server?.Id)" />

                        <div class="form-group mb-3">
                            <label>Select Application</label>
                            <select name="applicationId" class="form-select" required>
                                <option value="">-- Select Application --</option>
                                @foreach (var app in availableApps)
                                {
                                    <option value="@(app.Id)">@app.AssetName @(!string.IsNullOrEmpty(app.Version) ? $"(v{app.Version})" : "")</option>
                                }
                            </select>
                        </div>

                        <div class="form-group mb-3">
                            <label>Status</label>
                            <select name="status" class="form-select" required>
                                <option value="Running">Running</option>
                                <option value="Stopped">Stopped</option>
                                <option value="Pending">Pending</option>
                            </select>
                        </div>

                        <div class="form-group mb-3">
                            <label>Notes (Optional)</label>
                            <textarea name="notes" class="form-control" rows="2" placeholder="Installation notes..."></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-download"></i> Install Application
                        </button>
                    </form>
                }
                else
                {
                    <p class="text-muted">All applications are already installed on this server.</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Details" asp-route-id="@(server?.Id)" class="btn btn-info">
        <i class="fas fa-eye"></i> View Server
    </a>
    <a asp-action="Index" asp-route-assetType="Server" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Back
    </a>
</div>
