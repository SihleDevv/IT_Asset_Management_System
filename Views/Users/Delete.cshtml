@model IT_Asset_Management_System.Models.ApplicationUser

@{
    ViewData["Title"] = "Delete User";
    var userRole = ViewBag.UserRole as string ?? "No Role";
}

<div class="page-header mb-3">
    <h1>Delete User</h1>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <h4><i class="fas fa-exclamation-triangle"></i> Warning!</h4>
        <p>@TempData["ErrorMessage"]</p>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@{
    var computersCount = ViewBag.ComputersCount as int? ?? 0;
    var serversCount = ViewBag.ServersCount as int? ?? 0;
    var applicationsCount = ViewBag.ApplicationsCount as int? ?? 0;
    var itSupportTicketsCount = ViewBag.ITSupportTicketsCount as int? ?? 0;
    var hasDependencies = ViewBag.HasDependencies as bool? ?? false;
}

@if (hasDependencies)
{
    <div class="alert alert-warning">
        <h4><i class="fas fa-exclamation-triangle"></i> Warning: User has linked assets</h4>
        <p>This user is linked to the following assets:</p>
        <ul>
            @if (computersCount > 0)
            {
                <li><strong>@computersCount</strong> computer(s) assigned</li>
            }
            @if (serversCount > 0)
            {
                <li><strong>@serversCount</strong> server(s) as Project Manager</li>
            }
            @if (applicationsCount > 0)
            {
                <li><strong>@applicationsCount</strong> application(s) as Application Owner</li>
            }
            @if (itSupportTicketsCount > 0)
            {
                <li><strong>@itSupportTicketsCount</strong> IT Support ticket(s) (as customer, technician, or supervisor)</li>
            }
        </ul>
        <p class="mb-0"><strong>You must reassign or remove these dependencies before deleting this user.</strong></p>
    </div>
}

<div class="alert alert-danger">
    <i class="fas fa-exclamation-triangle"></i>
    <strong>Warning:</strong> Are you sure you want to delete this user? This action cannot be undone.
</div>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Full Name:</dt>
            <dd class="col-sm-9">@(Model?.FullName ?? "—")</dd>

            <dt class="col-sm-3">Email:</dt>
            <dd class="col-sm-9">@(Model?.Email ?? "—")</dd>

            <dt class="col-sm-3">Department:</dt>
            <dd class="col-sm-9">@(Model?.Department ?? "—")</dd>

            <dt class="col-sm-3">Role:</dt>
            <dd class="col-sm-9"><span class="badge bg-info">@userRole</span></dd>

            <dt class="col-sm-3">Status:</dt>
            <dd class="col-sm-9">
                @if (Model?.IsActive == true)
                {
                    <span class="badge bg-success">Active</span>
                }
                else
                {
                    <span class="badge bg-danger">Inactive</span>
                }
            </dd>

            <dt class="col-sm-3">Created Date:</dt>
            <dd class="col-sm-9">@(Model?.CreatedDate == null ? "N/A" : ((DateTime)Model.CreatedDate).ToString("yyyy-MM-dd"))</dd>
        </dl>

        <form asp-action="Delete" method="post" class="mt-4">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                @if (hasDependencies)
                {
                    <button type="submit" class="btn btn-danger" disabled>
                        <i class="fas fa-trash"></i> Cannot Delete - Dependencies Exist
                    </button>
                }
                else
                {
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash"></i> Delete User
                    </button>
                }
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

