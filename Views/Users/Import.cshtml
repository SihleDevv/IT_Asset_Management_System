@{
    ViewData["Title"] = "Import Users from CSV";
}

<div class="page-header mb-3">
    <h1>Import Users from CSV</h1>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["WarningMessage"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i>@TempData["WarningMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-times-circle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-upload me-2"></i>Upload CSV File</h5>
            </div>
            <div class="card-body">
                <form asp-action="Import" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label for="csvFile" class="form-label">Select CSV File</label>
                        <input type="file" class="form-control" id="csvFile" name="csvFile" accept=".csv" required />
                        <div class="form-text">
                            <i class="fas fa-info-circle me-1"></i>
                            Please upload a CSV file with the following columns: Full Name, Email, Department (optional), Role (optional), IsActive (optional)
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-upload me-2"></i>Import Users
                        </button>
                        <a asp-action="DownloadTemplate" class="btn btn-outline-secondary">
                            <i class="fas fa-download me-2"></i>Download Template
                        </a>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Back to Users
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Import Instructions</h5>
            </div>
            <div class="card-body">
                <h6>CSV Format:</h6>
                <ul class="small">
                    <li><strong>Full Name:</strong> Required</li>
                    <li><strong>Email:</strong> Required (must be unique)</li>
                    <li><strong>Department:</strong> Optional</li>
                    <li><strong>Role:</strong> Optional (default: Employee)</li>
                    <li><strong>IsActive:</strong> Optional (default: true)</li>
                </ul>
                <hr />
                <h6>Default Password:</h6>
                <div class="alert alert-info p-2 mb-2">
                    <strong>@Html.Raw("TempPass123!@#")</strong>
                </div>
                <p class="small mb-2">
                    <i class="fas fa-exclamation-triangle text-warning me-1"></i>
                    <strong>Important:</strong> All imported users will receive the default password above.
                </p>
                <p class="small mb-2">
                    <i class="fas fa-lock text-danger me-1"></i>
                    <strong>Security:</strong> Users will be <strong>forced to change their password</strong> on first login.
                </p>
                <hr />
                <h6>Notes:</h6>
                <ul class="small">
                    <li>Users with existing emails will be skipped</li>
                    <li>Valid roles: Admin, IT Manager, IT Support Supervisor, IT Support, Employee, Read Only</li>
                    <li>Password change is mandatory on first login</li>
                    <li>Share the default password securely with users</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@if (ViewBag.Results != null)
{
    <div class="card mt-4">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="fas fa-list me-2"></i>Import Results
                @if (ViewBag.SuccessCount != null || ViewBag.ErrorCount != null)
                {
                    <span class="badge bg-success ms-2">@ViewBag.SuccessCount Success</span>
                    <span class="badge bg-danger ms-2">@ViewBag.ErrorCount Errors</span>
                }
            </h5>
        </div>
        <div class="card-body">
            @if (ViewBag.DefaultPassword != null)
            {
                <div class="alert alert-warning mb-3">
                    <h6><i class="fas fa-key me-2"></i>Default Password for All Imported Users:</h6>
                    <p class="mb-0"><strong>@ViewBag.DefaultPassword</strong></p>
                    <small>Please share this password securely with the imported users. They will be required to change it on first login.</small>
                </div>
            }
            <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Result</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var result in (List<string>?)ViewBag.Results ?? new List<string>())
                        {
                            var isError = result.Contains("Error") || result.Contains("Failed") || result.Contains("Skipped");
                            <tr>
                                <td class="@(isError ? "text-danger" : "text-success")">
                                    <i class="fas @(isError ? "fa-times-circle" : "fa-check-circle") me-2"></i>@result
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
