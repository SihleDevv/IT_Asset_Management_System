@model IEnumerable<IT_Asset_Management_System.Models.ApplicationUser>

@{
    ViewData["Title"] = "Users Management";
    var userRoles = ViewBag?.UserRoles as IDictionary<string, string> ?? new Dictionary<string, string>();
}

<div class="page-header mb-3">
    <div class="d-flex justify-content-between align-items-center">
        <h1>Users Management</h1>
        <div>
            <a asp-action="PasswordManagement" class="btn btn-warning me-2">
                <i class="fas fa-key"></i> Password Management
            </a>
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary">
                <i class="fas fa-user-plus"></i> Add New User
            </a>
        </div>
    </div>
</div>

<!-- Search and Filter Section -->
<div class="card mb-3">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-8">
                <label for="searchTerm" class="form-label">Search Users</label>
                <div class="input-group">
                    <input type="text" 
                           class="form-control" 
                           id="searchTerm" 
                           name="searchTerm" 
                           value="@ViewBag.SearchTerm" 
                           placeholder="Search by Email, Full Name, Department, or Username..." />
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-search"></i> Search
                    </button>
                    @if (!string.IsNullOrWhiteSpace(ViewBag.SearchTerm as string))
                    {
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Clear
                        </a>
                    }
                </div>
            </div>
            
            <div class="col-md-4 text-end">
                <a asp-action="ExportToCsv" 
                   asp-route-searchTerm="@ViewBag.SearchTerm" 
                   class="btn btn-success">
                    <i class="fas fa-download"></i> Download CSV
                </a>
            </div>
        </form>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(ViewBag.SearchTerm as string))
{
    <div class="alert alert-info mb-3">
        <i class="fas fa-info-circle"></i> 
        Showing results for: <strong>@ViewBag.SearchTerm</strong>
        @if (Model != null && Model.Any())
        {
            <span> (@Model.Count() result(s))</span>
        }
    </div>
}

<div class="table-container">
    <table class="table table-hover table-striped">
        <thead class="table-light">
            <tr>
                <th>Full Name</th>
                <th>Email</th>
                <th>Department</th>
                <th>Role</th>
                <th>Status</th>
                <th>Created Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var user in Model)
                {
                    <tr>
                        <td><strong>@(user?.FullName ?? "—")</strong></td>
                        <td>@(user?.Email ?? "—")</td>
                        <td>@(user?.Department ?? "—")</td>
                        <td><span class="badge bg-info">@((user != null && userRoles.ContainsKey(user.Id)) ? userRoles[user.Id] : "—")</span></td>
                        <td>
                            @if (user?.IsActive == true)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </td>
                        <td>@(user?.CreatedDate == null ? "N/A" : ((DateTime)user.CreatedDate).ToString("yyyy-MM-dd"))</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@user?.Id" class="btn btn-sm btn-warning" title="Edit">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            @{
                                var currentUserId = ViewBag.CurrentUserId as string;
                                var isCurrentUser = user?.Id == currentUserId;
                            }
                            @if (!isCurrentUser)
                            {
                                <a asp-action="Delete" asp-route-id="@user?.Id" class="btn btn-sm btn-danger" title="Delete" onclick="return confirm('Are you sure you want to delete this user? This action cannot be undone.');">
                                    <i class="fas fa-trash"></i> Delete
                                </a>
                            }
                            else
                            {
                                <button type="button" class="btn btn-sm btn-danger" disabled title="You cannot delete your own account">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center">No users found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
