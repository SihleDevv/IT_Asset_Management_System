@model IEnumerable<IT_Asset_Management_System.Models.Application>

@{
    ViewData["Title"] = "License Report";
}

<h1>License Report</h1>

<div class="mb-3">
    <div class="btn-group">
        <button type="button" class="btn btn-success btn-sm dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="fas fa-download"></i> Export
        </button>
        <ul class="dropdown-menu">
            <li>
                <a class="dropdown-item" asp-action="ExportLicenseReportToCsv">
                    <i class="fas fa-file-csv"></i> Export as CSV
                </a>
            </li>
            <li>
                <a class="dropdown-item" asp-action="ExportLicenseReportToPdf">
                    <i class="fas fa-file-pdf"></i> Export as PDF
                </a>
            </li>
        </ul>
    </div>
    <button class="btn btn-secondary btn-sm ms-2" onclick="window.print()">Print Report</button>
    <a asp-action="Index" class="btn btn-secondary btn-sm ms-2">Back to Reports</a>
</div>

<div class="card">
    <div class="card-body">
        <h5>Total Licensed Applications: @Model.Count()</h5>
        <div class="table-responsive">
            <table class="table table-striped table-sm">
                <thead>
                    <tr>
                        <th>Asset Tag</th>
                        <th>Application Name</th>
                        <th>Vendor</th>
                        <th>Business Unit</th>
                        <th>Application Owner</th>
                        <th>License Holder</th>
                        <th>License Type</th>
                        <th>Total Licenses</th>
                        <th>Used</th>
                        <th>Available</th>
                        <th>Expiry Date</th>
                        <th>Days Until Expiry</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var daysUntilExpiry = item.LicenseExpiryDate.HasValue ? 
                            (item.LicenseExpiryDate.Value - DateTime.Now).Days : 0;
                        <tr class="@(daysUntilExpiry < 0 ? "table-danger" : daysUntilExpiry < 30 ? "table-warning" : "")">
                            <td><strong>@(item.AssetTag ?? "—")</strong></td>
                            <td>@item.AssetName</td>
                            <td>@(item.Vendor ?? "—")</td>
                            <td>@(item.BusinessUnit ?? "—")</td>
                            <td>@(item.ApplicationOwner ?? "—")</td>
                            <td>@(item.LicenseHolder ?? "—")</td>
                            <td>@item.LicenseType</td>
                            <td>@(item.TotalLicenses?.ToString() ?? "—")</td>
                            <td>@(item.UsedLicenses?.ToString() ?? "—")</td>
                            <td>@((item.TotalLicenses ?? 0) - (item.UsedLicenses ?? 0))</td>
                            <td>@(item.LicenseExpiryDate?.ToString("yyyy-MM-dd") ?? "N/A")</td>
                            <td>
                                @if (item.LicenseExpiryDate.HasValue)
                                {
                                    if (daysUntilExpiry < 0)
                                    {
                                        <span class="text-danger font-weight-bold">Expired</span>
                                    }
                                    else if (daysUntilExpiry < 30)
                                    {
                                        <span class="text-warning font-weight-bold">@daysUntilExpiry days</span>
                                    }
                                    else
                                    {
                                        @daysUntilExpiry <span>days</span>
                                    }
                                }
                                else
                                {
                                    <span>N/A</span>
                                }
                            </td>
                            <td>@item.Status</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>