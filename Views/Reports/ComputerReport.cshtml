@model IEnumerable<IT_Asset_Management_System.Models.Computer>

@{
    ViewData["Title"] = "Computer Report";

    // Ensure Model isn't null and remove nulls
    var list = (Model ?? Enumerable.Empty<IT_Asset_Management_System.Models.Computer>())
               .Where(c => !string.IsNullOrEmpty(c.AssetTag)
                   && !string.IsNullOrEmpty(c.AssetName)
                   && c.AssetTag != null
                   && c.AssetName != null)
               .ToList();
}

<div class="page-header mb-3">
    <h1>Computer Report</h1>
</div>

<!-- Search and Filter Section -->
<div class="card mb-3">
    <div class="card-body">
        <form asp-action="ComputerReport" method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label for="searchTerm" class="form-label">Search</label>
                <input type="text" 
                       class="form-control" 
                       id="searchTerm" 
                       name="searchTerm" 
                       value="@ViewBag.SearchTerm" 
                       placeholder="Search by Asset Tag, Name, Serial Number, Location, Brand, or Assigned To..." />
            </div>
            
            <div class="col-md-3">
                <label for="statusFilter" class="form-label">Status</label>
                <select name="statusFilter" id="statusFilter" class="form-select">
                    <option value="">All Statuses</option>
                    @if (ViewBag.Statuses != null)
                    {
                        foreach (var status in ViewBag.Statuses)
                        {
                            <option value="@status" selected="@(ViewBag.StatusFilter as string == status)">@status</option>
                        }
                    }
                </select>
            </div>
            
            <div class="col-md-4 d-flex gap-2 align-items-end">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="fas fa-search"></i> Filter
                </button>
                <a asp-action="ComputerReport" class="btn btn-secondary btn-sm">
                    <i class="fas fa-times"></i> Clear
                </a>
                <div class="btn-group">
                    <button type="button" class="btn btn-success btn-sm dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-download"></i> Export
                    </button>
                    <ul class="dropdown-menu">
                        <li>
                            <a class="dropdown-item" asp-action="ExportComputerReportToCsv" 
                               asp-route-searchTerm="@ViewBag.SearchTerm" 
                               asp-route-statusFilter="@ViewBag.StatusFilter">
                                <i class="fas fa-file-csv"></i> Export as CSV
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-action="ExportComputerReportToPdf" 
                               asp-route-searchTerm="@ViewBag.SearchTerm" 
                               asp-route-statusFilter="@ViewBag.StatusFilter">
                                <i class="fas fa-file-pdf"></i> Export as PDF
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h5>Total Computers: @list.Count()</h5>
        <div class="table-responsive">
            <table class="table table-striped table-sm">
                <thead>
                    <tr>
                        <th>Asset Tag</th>
                        <th>Name</th>
                        <th>Serial Number</th>
                        <th>Location</th>
                        <th>Assigned To</th>
                        <th>Operating System</th>
                        <th>Status</th>
                        <th>Purchase Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in list)
                    {
                        <tr>
                            <td><strong>@(item?.AssetTag ?? "—")</strong></td>
                            <td>@(item != null && !string.IsNullOrEmpty(item.AssetName) ? item.AssetName : "—")</td>
                            <td>@(item?.SerialNumber ?? "—")</td>
                            <td>@(item?.Location ?? "—")</td>
                            <td>@(item?.AssignedTo ?? "—")</td>
                            <td>@(item?.OperatingSystem ?? "—")</td>
                            <td>
                                @if (item != null && !string.IsNullOrEmpty(item.Status))
                                {
                                    if (item.Status == "Available" || item.Status == "In Use")
                                    {
                                        <span class="badge bg-success">@item.Status</span>
                                    }
                                    else if (item.Status == "Under Maintenance")
                                    {
                                        <span class="badge bg-warning">@item.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@item.Status</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>@(item?.PurchaseDate.ToString("yyyy-MM-dd") ?? "N/A")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
