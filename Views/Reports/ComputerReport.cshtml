@model IEnumerable<IT_Asset_Management_System.Models.Computer>

@{
    ViewData["Title"] = "Computer Report";

    // Ensure Model isn't null and remove nulls
    var list = (Model ?? Enumerable.Empty<IT_Asset_Management_System.Models.Computer>())
               .Where(c => !string.IsNullOrEmpty(c.AssetTag)
                   && !string.IsNullOrEmpty(c.AssetName)
                   && c.AssetTag != null
                   && c.AssetName != null)
               .ToList();
}

<div class="page-header">
    <h1>Computer Report</h1>
</div>

<div class="mb-3">
    <button class="btn btn-success" onclick="window.print()">
        <i class="fas fa-print"></i> Print Report
    </button>
</div>

<div class="card">
    <div class="card-body">
        <h5>Total Computers: @list.Count()</h5>
        <div class="table-responsive">
            <table class="table table-striped table-sm">
                <thead>
                    <tr>
                        <th>Asset Tag</th>
                        <th>Name</th>
                        <th>Brand</th>
                        <th>Model</th>
                        <th>Serial Number</th>
                        <th>Location</th>
                        <th>Vendor</th>
                        <th>Assigned To</th>
                        <th>Operating System</th>
                        <th>Status</th>
                        <th>Purchase Date</th>
                        <th>Purchase Price</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in list)
                    {
                        <tr>
                            <td>@(item?.AssetTag ?? "—")</td>
                            <td>@(item != null && !string.IsNullOrEmpty(item.AssetName) ? item.AssetName : "—")</td>
                            <td>@(item?.Brand ?? "—")</td>
                            <td>@(item?.Model ?? "—")</td>
                            <td>@(item?.SerialNumber ?? "—")</td>
                            <td>@(item?.Location ?? "—")</td>
                            <td>@(item?.Vendor ?? "—")</td>
                            <td>@(item?.AssignedTo ?? "—")</td>
                            <td>@(item?.OperatingSystem ?? "—")</td>
                            <td>
                                @if (item != null && !string.IsNullOrEmpty(item.Status))
                                {
                                    if (item.Status == "Available" || item.Status == "In Use")
                                    {
                                        <span class="badge bg-success">@item.Status</span>
                                    }
                                    else if (item.Status == "Under Maintenance")
                                    {
                                        <span class="badge bg-warning">@item.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">@item.Status</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>@(item?.PurchaseDate.ToString("yyyy-MM-dd") ?? "N/A")</td>
                            <td>@(item?.PurchasePrice != null ? string.Format("R {0:N2}", item.PurchasePrice) : "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
