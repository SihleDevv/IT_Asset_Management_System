@model IEnumerable<IT_Asset_Management_System.Models.Application>

@{
    ViewData["Title"] = "Application Report";

    // Ensure Model isn't null and remove nulls
    var list = (Model ?? Enumerable.Empty<IT_Asset_Management_System.Models.Application>())
               .Where(a => !string.IsNullOrEmpty(a.AssetTag)
                   && !string.IsNullOrEmpty(a.AssetName)
                   && a.AssetTag != null
                   && a.AssetName != null)
               .ToList();
}

<h1>Application Report</h1>

<div class="mb-3">
    <button class="btn btn-success" onclick="window.print()">Print Report</button>
    <a asp-action="Index" class="btn btn-secondary">Back to Reports</a>
</div>

<div class="card">
    <div class="card-body">
        <h5>Total Applications: @list.Count()</h5>
        <div class="table-responsive">
            <table class="table table-striped table-sm">
                <thead>
                    <tr>
                        <th>Asset Tag</th>
                        <th>Application Name</th>
                        <th>Brand</th>
                        <th>Model</th>
                        <th>Version</th>
                        <th>Category</th>
                        <th>Business Unit</th>
                        <th>Application Owner</th>
                        <th>License Holder</th>
                        <th>Vendor</th>
                        <th>Location</th>
                        <th>Status</th>
                        <th>Requires License</th>
                        <th>License Type</th>
                        <th>License Expiry</th>
                        <th>Servers Using</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in list)
                    {
                        <tr>
                            <td>@(item?.AssetTag ?? "—")</td>
                            <td>@(item?.AssetName ?? "—")</td>
                            <td>@(item?.Brand ?? "—")</td>
                            <td>@(item?.Model ?? "—")</td>
                            <td>@(item?.Version ?? "—")</td>
                            <td>@(item?.Category ?? "—")</td>
                            <td>@(item?.BusinessUnit ?? "—")</td>
                            <td>@(item?.ApplicationOwner ?? "—")</td>
                            <td>@(item?.LicenseHolder ?? "—")</td>
                            <td>@(item?.Vendor ?? "—")</td>
                            <td>@(item?.Location ?? "—")</td>
                            <td>
                                @if (item != null)
                                {
                                    @if (item.Status == "Enabled" || item.Status == "Active")
                                    {
                                        <span class="badge bg-success">@item.Status</span>
                                    }
                                    else if (item.Status == "Disabled" || item.Status == "Expired")
                                    {
                                        <span class="badge bg-warning">@item.Status</span>
                                    }
                                    else if (item.Status == "Deprecated")
                                    {
                                        <span class="badge bg-danger">@item.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.Status</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>@((item?.RequiresLicense == true) ? "Yes" : "No")</td>
                            <td>@(item?.LicenseType ?? "—")</td>
                            <td>
                                @if (item != null && item.RequiresLicense == true && item.LicenseExpiryDate.HasValue == true)
                                {
                                    var expiryDate = item.LicenseExpiryDate.Value;
                                    if (expiryDate < DateTime.Now)
                                    {
                                        <span class="badge bg-danger">Expired: @expiryDate.ToString("yyyy-MM-dd")</span>
                                    }
                                    else if (expiryDate <= DateTime.Now.AddDays(30))
                                    {
                                        <span class="badge bg-warning">Expires: @expiryDate.ToString("yyyy-MM-dd")</span>
                                    }
                                    else
                                    {
                                        <span class="text-success">@expiryDate.ToString("yyyy-MM-dd")</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </td>
                            <td>
                                @{
                                    var serverCount = 0;
                                    var serverCounts = ViewBag.ServerCounts as Dictionary<int, int>;
                                    if (item != null && serverCounts != null && serverCounts.ContainsKey(item.Id))
                                    {
                                        serverCount = serverCounts[item.Id];
                                    }
                                }
                                @if (serverCount > 0)
                                {
                                    <span class="badge bg-info">@serverCount Server(s)</span>
                                }
                                else
                                {
                                    <span class="text-muted">0 Servers</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
