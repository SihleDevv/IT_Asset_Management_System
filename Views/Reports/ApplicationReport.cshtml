@model IEnumerable<IT_Asset_Management_System.Models.Application>

@{
    ViewData["Title"] = "Application Report";

    // Ensure Model isn't null and remove nulls
    var list = (Model ?? Enumerable.Empty<IT_Asset_Management_System.Models.Application>())
               .Where(a => !string.IsNullOrEmpty(a.AssetTag)
                   && !string.IsNullOrEmpty(a.AssetName)
                   && a.AssetTag != null
                   && a.AssetName != null)
               .ToList();
}

<div class="page-header mb-3">
    <h1>Application Report</h1>
</div>

<!-- Search and Filter Section -->
<div class="card mb-3">
    <div class="card-body">
        <form asp-action="ApplicationReport" method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label for="searchTerm" class="form-label">Search</label>
                <input type="text" 
                       class="form-control" 
                       id="searchTerm" 
                       name="searchTerm" 
                       value="@ViewBag.SearchTerm" 
                       placeholder="Search by Asset Tag, Name, Version, Vendor, Category, or Location..." />
            </div>
            
            <div class="col-md-3">
                <label for="statusFilter" class="form-label">Status</label>
                <select name="statusFilter" id="statusFilter" class="form-select">
                    <option value="">All Statuses</option>
                    @if (ViewBag.Statuses != null)
                    {
                        foreach (var status in ViewBag.Statuses)
                        {
                            <option value="@status" selected="@(ViewBag.StatusFilter as string == status)">@status</option>
                        }
                    }
                </select>
            </div>
            
            <div class="col-md-4 d-flex gap-2 align-items-end">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="fas fa-search"></i> Filter
                </button>
                <a asp-action="ApplicationReport" class="btn btn-secondary btn-sm">
                    <i class="fas fa-times"></i> Clear
                </a>
                <div class="btn-group">
                    <button type="button" class="btn btn-success btn-sm dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-download"></i> Export
                    </button>
                    <ul class="dropdown-menu">
                        <li>
                            <a class="dropdown-item" asp-action="ExportApplicationReportToCsv" 
                               asp-route-searchTerm="@ViewBag.SearchTerm" 
                               asp-route-statusFilter="@ViewBag.StatusFilter">
                                <i class="fas fa-file-csv"></i> Export as CSV
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-action="ExportApplicationReportToPdf" 
                               asp-route-searchTerm="@ViewBag.SearchTerm" 
                               asp-route-statusFilter="@ViewBag.StatusFilter">
                                <i class="fas fa-file-pdf"></i> Export as PDF
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <h5>Total Applications: @list.Count()</h5>
        <div class="table-responsive">
            <table class="table table-striped table-sm">
                <thead>
                    <tr>
                        <th>Asset Tag</th>
                        <th>Application Name</th>
                        <th>Version</th>
                        <th>Category</th>
                        <th>Vendor</th>
                        <th>Status</th>
                        <th>Requires License</th>
                        <th>License Type</th>
                        <th>License Expiry</th>
                        <th>Servers Using</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in list)
                    {
                        <tr>
                            <td><strong>@(item?.AssetTag ?? "—")</strong></td>
                            <td>@(item?.AssetName ?? "—")</td>
                            <td>@(item?.Version ?? "—")</td>
                            <td>@(item?.Category ?? "—")</td>
                            <td>@(item?.Vendor ?? "—")</td>
                            <td>
                                @if (item != null)
                                {
                                    @if (item.Status == "Enabled" || item.Status == "Active")
                                    {
                                        <span class="badge bg-success">@item.Status</span>
                                    }
                                    else if (item.Status == "Disabled" || item.Status == "Expired")
                                    {
                                        <span class="badge bg-warning">@item.Status</span>
                                    }
                                    else if (item.Status == "Deprecated")
                                    {
                                        <span class="badge bg-danger">@item.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@item.Status</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>@((item?.RequiresLicense == true) ? "Yes" : "No")</td>
                            <td>@(item?.LicenseType ?? "—")</td>
                            <td>
                                @if (item != null && item.RequiresLicense == true && item.LicenseExpiryDate.HasValue == true)
                                {
                                    var expiryDate = item.LicenseExpiryDate.Value;
                                    if (expiryDate < DateTime.Now)
                                    {
                                        <span class="badge bg-danger">Expired: @expiryDate.ToString("yyyy-MM-dd")</span>
                                    }
                                    else if (expiryDate <= DateTime.Now.AddDays(30))
                                    {
                                        <span class="badge bg-warning">Expires: @expiryDate.ToString("yyyy-MM-dd")</span>
                                    }
                                    else
                                    {
                                        <span class="text-success">@expiryDate.ToString("yyyy-MM-dd")</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </td>
                            <td>
                                @{
                                    var serverCount = 0;
                                    var serverCounts = ViewBag.ServerCounts as Dictionary<int, int>;
                                    if (item != null && serverCounts != null && serverCounts.ContainsKey(item.Id))
                                    {
                                        serverCount = serverCounts[item.Id];
                                    }
                                }
                                @if (serverCount > 0)
                                {
                                    <span class="badge bg-info">@serverCount Server(s)</span>
                                }
                                else
                                {
                                    <span class="text-muted">0 Servers</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
