@{
    ViewData["Title"] = "Asset Summary";
    var totalComputers = ViewBag?.TotalComputers ?? 0;
    var totalServers = ViewBag?.TotalServers ?? 0;
    var totalApplications = ViewBag?.TotalApplications ?? 0;
    var computersByStatus = ViewBag?.ComputersByStatus as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var serversByStatus = ViewBag?.ServersByStatus as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var applicationsByStatus = ViewBag?.ApplicationsByStatus as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<div class="page-header">
    <h1>Asset Summary Report</h1>
</div>

<div class="mb-3">
    <button class="btn btn-success" onclick="window.print()">
        <i class="fas fa-print"></i> Print Report
    </button>
</div>

<div class="dashboard-cards d-flex gap-3 mb-4">
    <div class="stat-card p-3 border rounded">
        <h5>Total Computers</h5>
        <div class="stat-value fs-4">@totalComputers</div>
    </div>

    <div class="stat-card p-3 border rounded">
        <h5>Total Servers</h5>
        <div class="stat-value fs-4">@totalServers</div>
    </div>

    <div class="stat-card p-3 border rounded">
        <h5>Total Applications</h5>
        <div class="stat-value fs-4">@totalApplications</div>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header"><h5>Computers by Status</h5></div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    @if (computersByStatus.Any())
                    {
                        foreach (var s in computersByStatus)
                        {
                            <li class="mb-2"><strong>@(s.Status ?? "Unknown"): </strong> @(s.Count ?? 0)</li>
                        }
                    }
                    else
                    {
                        <li class="text-muted">No data</li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header"><h5>Servers by Status</h5></div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    @if (serversByStatus.Any())
                    {
                        foreach (var s in serversByStatus)
                        {
                            <li class="mb-2"><strong>@(s.Status ?? "Unknown"): </strong> @(s.Count ?? 0)</li>
                        }
                    }
                    else
                    {
                        <li class="text-muted">No data</li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header"><h5>Applications by Status</h5></div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    @if (applicationsByStatus.Any())
                    {
                        foreach (var s in applicationsByStatus)
                        {
                            <li class="mb-2"><strong>@(s.Status ?? "Unknown"): </strong> @(s.Count ?? 0)</li>
                        }
                    }
                    else
                    {
                        <li class="text-muted">No data</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>
