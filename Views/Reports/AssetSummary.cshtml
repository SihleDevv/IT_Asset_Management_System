@{
    ViewData["Title"] = "Asset Summary";
    var totalComputers = ViewBag?.TotalComputers ?? 0;
    var totalServers = ViewBag?.TotalServers ?? 0;
    var totalApplications = ViewBag?.TotalApplications ?? 0;
    var computersByStatus = ViewBag?.ComputersByStatus as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var serversByStatus = ViewBag?.ServersByStatus as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var applicationsByStatus = ViewBag?.ApplicationsByStatus as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var assetTypeFilter = ViewBag?.AssetTypeFilter as string ?? "";
}

<div class="page-header mb-3">
    <h1>Asset Summary Report</h1>
</div>

<!-- Filter and Export Section -->
<div class="card mb-3">
    <div class="card-body">
        <form asp-action="AssetSummary" method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label for="assetTypeFilter" class="form-label">Filter by Asset Type</label>
                <select name="assetTypeFilter" id="assetTypeFilter" class="form-select">
                    <option value="">All Asset Types</option>
                    <option value="Computer" selected="@(assetTypeFilter == "Computer")">Computers</option>
                    <option value="Server" selected="@(assetTypeFilter == "Server")">Servers</option>
                    <option value="Application" selected="@(assetTypeFilter == "Application")">Applications</option>
                </select>
            </div>
            
            <div class="col-md-8 d-flex gap-2 align-items-end">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="fas fa-filter"></i> Apply Filter
                </button>
                <a asp-action="AssetSummary" class="btn btn-secondary btn-sm">
                    <i class="fas fa-times"></i> Clear
                </a>
                <div class="btn-group">
                    <button type="button" class="btn btn-success btn-sm dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-download"></i> Export
                    </button>
                    <ul class="dropdown-menu">
                        <li>
                            <a class="dropdown-item" asp-action="ExportAssetSummaryToCsv" 
                               asp-route-assetTypeFilter="@assetTypeFilter">
                                <i class="fas fa-file-csv"></i> Export as CSV
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-action="ExportAssetSummaryToPdf" 
                               asp-route-assetTypeFilter="@assetTypeFilter">
                                <i class="fas fa-file-pdf"></i> Export as PDF
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="dashboard-cards d-flex gap-3 mb-4">
    <div class="stat-card p-3 border rounded">
        <h5>Total Computers</h5>
        <div class="stat-value fs-4">@totalComputers</div>
    </div>

    <div class="stat-card p-3 border rounded">
        <h5>Total Servers</h5>
        <div class="stat-value fs-4">@totalServers</div>
    </div>

    <div class="stat-card p-3 border rounded">
        <h5>Total Applications</h5>
        <div class="stat-value fs-4">@totalApplications</div>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header"><h5>Computers by Status</h5></div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    @if (computersByStatus.Any())
                    {
                        foreach (var s in computersByStatus)
                        {
                            <li class="mb-2"><strong>@(s.Status ?? "Unknown"): </strong> @(s.Count ?? 0)</li>
                        }
                    }
                    else
                    {
                        <li class="text-muted">No data</li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header"><h5>Servers by Status</h5></div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    @if (serversByStatus.Any())
                    {
                        foreach (var s in serversByStatus)
                        {
                            <li class="mb-2"><strong>@(s.Status ?? "Unknown"): </strong> @(s.Count ?? 0)</li>
                        }
                    }
                    else
                    {
                        <li class="text-muted">No data</li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header"><h5>Applications by Status</h5></div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    @if (applicationsByStatus.Any())
                    {
                        foreach (var s in applicationsByStatus)
                        {
                            <li class="mb-2"><strong>@(s.Status ?? "Unknown"): </strong> @(s.Count ?? 0)</li>
                        }
                    }
                    else
                    {
                        <li class="text-muted">No data</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>
