@model IT_Asset_Management_System.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register New User";
}

<div class="page-header mb-3">
    <h1>@ViewData["Title"]</h1>
</div>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <form asp-action="Register" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label asp-for="Email" class="form-label"></label>
                        </div>
                        <div class="col-md-9">
                            <input asp-for="Email" class="form-control" autocomplete="off" value="" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label asp-for="FullName" class="form-label"></label>
                        </div>
                        <div class="col-md-9">
                            <input asp-for="FullName" class="form-control" autocomplete="off" value="" />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label asp-for="Department" class="form-label"></label>
                        </div>
                        <div class="col-md-9">
                            <select asp-for="Department" class="form-control">
                                <option value="" selected>-- Select Department --</option>
                                <option value="HR">HR</option>
                                <option value="Admin">Admin</option>
                                <option value="IT">IT</option>
                                <option value="Finance">Finance</option>
                                <option value="Operations">Operations</option>
                                <option value="Sales">Sales</option>
                                <option value="Marketing">Marketing</option>
                                <option value="Other">Other</option>
                            </select>
                            <span asp-validation-for="Department" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label asp-for="Role" class="form-label"></label>
                        </div>
                        <div class="col-md-9">
                            <select asp-for="Role" class="form-control">
                                <option value="" selected>-- Select Role --</option>
                                <option value="Admin">Admin</option>
                                <option value="IT Manager">IT Manager</option>
                                <option value="IT Support Supervisor">IT Support Supervisor</option>
                                <option value="IT Support">IT Support</option>
                                <option value="Employee">Employee</option>
                                <option value="Read Only">Read Only</option>
                            </select>
                            <span asp-validation-for="Role" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label asp-for="Password" class="form-label"></label>
                        </div>
                        <div class="col-md-9">
                            <input asp-for="Password" class="form-control" type="password" autocomplete="new-password" value="" />
                            <small class="form-text text-muted">Password must be 8-30 characters, include at least one digit and one special character [~!@@#&#36;^&amp;*?&gt;&lt;]</small>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label asp-for="ConfirmPassword" class="form-label"></label>
                        </div>
                        <div class="col-md-9">
                            <input asp-for="ConfirmPassword" class="form-control" type="password" autocomplete="new-password" value="" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-3"></div>
                        <div class="col-md-9">
                            <button type="submit" class="btn btn-primary">Register</button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Cancel</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
