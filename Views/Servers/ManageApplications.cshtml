@model IT_Asset_Management_System.ViewModels.ServerApplicationViewModel
@{
    ViewData["Title"] = "Install Application on Server";
}

<div class="page-header">
    <h1>Install Application - @Model.Server?.AssetName</h1>
    <p class="text-muted">Asset Tag: @Model.Server?.AssetTag | IP Address: @Model.Server?.IPAddress</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header bg-success text-white">
                <h5><i class="fas fa-check-circle"></i> Installed Applications</h5>
            </div>
            <div class="card-body">
                @if (Model.InstalledApplications.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-striped">
                            <thead class="table-dark">
                                <tr>
                                    <th>Application</th>
                                    <th>Version</th>
                                    <th>Installed By</th>
                                    <th>Installation Date</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var app in Model.InstalledApplications)
                                {
                                    <tr>
                                        <td>@(app?.Application?.AssetName ?? "—")</td>
                                        <td>@(app?.InstalledVersion ?? "—")</td>
                                        <td>
                                            @if (app != null && !string.IsNullOrEmpty(app.CreatedBy))
                                            {
                                                <span class="badge bg-primary">@app.CreatedBy</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">N/A</span>
                                            }
                                        </td>
                                        <td>@(app != null ? app.InstallationDate.ToString("yyyy-MM-dd HH:mm") : "—")</td>
                                        <td>
                                            @if (app != null)
                                            {
                                                @if (app.Status == "Running")
                                                {
                                                    <span class="badge bg-success">@app.Status</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning">@app.Status</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            @if (app != null)
                                            {
                                                <form asp-action="UninstallApplication" method="post" class="d-inline">
                                                    <input type="hidden" name="id" value="@app.Id" />
                                                    <input type="hidden" name="serverId" value="@(Model.Server?.Id ?? 0)" />
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-danger" title="Uninstall" onclick="return confirm('Are you sure you want to uninstall this application?');">
                                                        <i class="fas fa-trash"></i> Uninstall
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No applications installed on this server.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <h5><i class="fas fa-plus-circle"></i> Install New Application</h5>
            </div>
            <div class="card-body">
                @if (Model.AvailableApplications.Any())
                {
                    <form asp-action="InstallApplication" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="serverId" value="@Model.Server?.Id" />

                        <div class="mb-3">
                            <label for="applicationId" class="form-label">Select Application <span class="text-danger">*</span></label>
                            <select name="applicationId" id="applicationId" class="form-select" required>
                                <option value="">-- Select Application --</option>
                                @foreach (var app in Model.AvailableApplications)
                                {
                                    <option value="@(app?.Id ?? 0)">@(app?.AssetName ?? "Unknown") (@(app?.Version ?? "—")) - @(app?.Vendor ?? "—")</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="installedVersion" class="form-label">Installed Version <span class="text-danger">*</span></label>
                            <input type="text" name="installedVersion" id="installedVersion" class="form-control" placeholder="e.g., 1.0.0" required />
                            <small class="form-text text-muted">Enter the version installed on this server</small>
                        </div>

                        <div class="mb-3">
                            <label for="status" class="form-label">Status <span class="text-danger">*</span></label>
                            <select name="status" id="status" class="form-select" required>
                                <option value="Running">Running</option>
                                <option value="Stopped">Stopped</option>
                                <option value="Maintenance">Maintenance</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="notes" class="form-label">Notes (Optional)</label>
                            <textarea name="notes" id="notes" class="form-control" rows="3" placeholder="Additional notes about this installation"></textarea>
                        </div>

                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> <strong>Note:</strong> This installation will be recorded with your username: <strong>@User.Identity?.Name</strong>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-download"></i> Install Application
                        </button>
                    </form>
                }
                else
                {
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i> All available applications are already installed on this server.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Details" asp-route-id="@Model.Server?.Id" class="btn btn-info">
        <i class="fas fa-eye"></i> View Server Details
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Back to Servers List
    </a>
</div>

