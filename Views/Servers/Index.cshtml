@model IEnumerable<IT_Asset_Management_System.Models.Server>
@{
    ViewData["Title"] = "Servers";
}

<h1>Servers</h1>

@if (User.IsInRole("Admin") || User.IsInRole("IT Manager"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Create New Server</a>
    </p>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Asset Tag</th>
                <th>Asset Name</th>
                <th>IP Address</th>
                <th>Type</th>
                <th>Purpose</th>
                <th>RAM</th>
                <th>Storage</th>
                <th>Status</th>
                <th>Installed Apps</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Where(s => s != null && !string.IsNullOrWhiteSpace(s.AssetTag) && !string.IsNullOrWhiteSpace(s.AssetName)))
            {
                <tr>
                    <td>@item.AssetTag</td>
                    <td>@item.AssetName</td>
                    <td>@item.IPAddress</td>
                    <td>@item.ServerType</td>
                    <td>@item.Purpose</td>
                    <td>@item.RAM GB</td>
                    <td>@item.Storage GB</td>
                    <td>
                        @if (item.Status == "Active")
                        {
                            <span class="badge bg-success">@item.Status</span>
                        }
                        else if (item.Status == "Inactive")
                        {
                            <span class="badge bg-warning">@item.Status</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">@item.Status</span>
                        }
                    </td>
                    <td>
                        <span class="badge bg-info">@(item.ServerApplications?.Count ?? 0) installed</span>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                        @if (User.IsInRole("Admin") || User.IsInRole("IT Manager"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="ManageApplications" asp-route-id="@item.Id" class="btn btn-sm btn-success">Install Application</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>