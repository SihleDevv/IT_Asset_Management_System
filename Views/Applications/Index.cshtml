@model IEnumerable<IT_Asset_Management_System.Models.Application>
@{
    ViewData["Title"] = "Applications";
}

<h1>Applications</h1>

@if (TempData["LicenseWarning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-triangle"></i> <strong>License Expiration Warning:</strong> @TempData["LicenseWarning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (User.IsInRole("Admin") || User.IsInRole("IT Manager"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Create New Application</a>
    </p>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Asset Name</th>
                <th>Version</th>
                <th>Vendor</th>
                <th>Category</th>
                <th>Requires License</th>
                <th>License Expiry</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Where(a => a != null && !string.IsNullOrWhiteSpace(a.AssetName)))
            {
                <tr>
                    <td>@item.AssetName</td>
                    <td>@item.Version</td>
                    <td>@item.Vendor</td>
                    <td>@item.Category</td>
                    <td>
                        @if (item.RequiresLicense)
                        {
                            <span class="badge bg-warning">Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">No</span>
                        }
                    </td>
                    <td>
                        @if (item.LicenseExpiryDate.HasValue)
                        {
                            var daysUntilExpiry = (item.LicenseExpiryDate.Value - DateTime.Now).Days;
                            if (daysUntilExpiry < 0)
                            {
                                <span class="text-danger"><i class="fas fa-exclamation-circle"></i> Expired</span>
                            }
                            else if (daysUntilExpiry <= 15)
                            {
                                <span class="text-danger"><i class="fas fa-exclamation-triangle"></i> @item.LicenseExpiryDate.Value.ToString("yyyy-MM-dd") (@daysUntilExpiry days)</span>
                            }
                            else if (daysUntilExpiry < 30)
                            {
                                <span class="text-warning">@item.LicenseExpiryDate.Value.ToString("yyyy-MM-dd")</span>
                            }
                            else
                            {
                                @item.LicenseExpiryDate.Value.ToString("yyyy-MM-dd")
                            }
                        }
                        else
                        {
                            <span class="text-muted">N/A</span>
                        }
                    </td>
                    <td>
                        @if (item.Status == "Active")
                        {
                            <span class="badge bg-success">@item.Status</span>
                        }
                        else if (item.Status == "Expired")
                        {
                            <span class="badge bg-danger">@item.Status</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">@item.Status</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info" title="Details">
                            <i class="fas fa-eye"></i>
                        </a>
                        @if (User.IsInRole("Admin") || User.IsInRole("IT Manager"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning" title="Edit">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" title="Delete">
                                <i class="fas fa-trash"></i>
                            </a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>