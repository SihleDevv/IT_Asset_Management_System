@model IEnumerable<IT_Asset_Management_System.Models.ITSupportTicket>
@{
    ViewData["Title"] = "IT Support Tickets";
    var isAdminOrITManager = ViewBag.IsAdminOrITManager as bool? ?? false;
    var isITSupportSupervisor = ViewBag.IsITSupportSupervisor as bool? ?? false;
    var isITSupport = ViewBag.IsITSupport as bool? ?? false;
    var statusFilter = ViewBag.StatusFilter as string;
    var priorityFilter = ViewBag.PriorityFilter as string;
    var showAssignedTo = isAdminOrITManager || isITSupportSupervisor || isITSupport || !isAdminOrITManager;
}

<div class="page-header mb-3">
    <h1>IT Support Tickets</h1>
    <p class="text-muted">Report and manage asset issues</p>
    @if (ViewBag.ExpiredTicketsCount != null && (int)ViewBag.ExpiredTicketsCount > 0)
    {
        <div class="alert alert-danger mt-2">
            <i class="fas fa-exclamation-triangle"></i> <strong>Warning:</strong> @ViewBag.ExpiredTicketsCount ticket(s) have exceeded the 3-day resolution deadline and require immediate attention.
        </div>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select name="status" class="form-select">
                    <option value="">All Statuses</option>
                    <option value="Pending" selected="@(statusFilter == "Pending")">Pending</option>
                    <option value="In Progress" selected="@(statusFilter == "In Progress")">In Progress</option>
                    <option value="Resolved" selected="@(statusFilter == "Resolved")">Resolved</option>
                    <option value="Closed" selected="@(statusFilter == "Closed")">Closed</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Priority</label>
                <select name="priority" class="form-select">
                    <option value="">All Priorities</option>
                    <option value="Low" selected="@(priorityFilter == "Low")">Low</option>
                    <option value="Medium" selected="@(priorityFilter == "Medium")">Medium</option>
                    <option value="High" selected="@(priorityFilter == "High")">High</option>
                    <option value="Critical" selected="@(priorityFilter == "Critical")">Critical</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary me-2">Filter</button>
                <a asp-action="Index" class="btn btn-secondary me-2">Clear</a>
                <a asp-action="ExportToCsv" asp-route-status="@statusFilter" asp-route-priority="@priorityFilter" class="btn btn-sm btn-info" title="Download CSV">
                    <i class="fas fa-download"></i> CSV
                </a>
            </div>
            <div class="col-md-3 d-flex align-items-end justify-content-end">
                <a asp-action="Create" class="btn btn-success">
                    <i class="fas fa-plus"></i> New Ticket
                </a>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Ticket ID</th>
                <th>Subject</th>
                @if (isAdminOrITManager)
                {
                    <th>Reported By</th>
                }
                @if (showAssignedTo)
                {
                    <th>Assigned To</th>
                }
                <th>Priority</th>
                <th>Status</th>
                <th>Related Asset</th>
                <th>Created Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ticket in Model)
            {
                <tr>
                    <td>#@ticket.Id</td>
                    <td>@ticket.Subject</td>
                    @if (isAdminOrITManager)
                    {
                        <td>@(ticket.ReportedByUser?.FullName ?? ticket.ReportedByUser?.Email ?? "N/A")</td>
                    }
                    @if (showAssignedTo)
                    {
                        <td>@(ticket.AssignedToUser?.FullName ?? ticket.AssignedToUser?.Email ?? "Unassigned")</td>
                    }
                    <td>
                        @if (ticket.Priority == "Critical")
                        {
                            <span class="badge bg-danger">@ticket.Priority</span>
                        }
                        else if (ticket.Priority == "High")
                        {
                            <span class="badge bg-warning">@ticket.Priority</span>
                        }
                        else if (ticket.Priority == "Medium")
                        {
                            <span class="badge bg-info">@ticket.Priority</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@ticket.Priority</span>
                        }
                    </td>
                    <td>
                        @{
                            var daysSinceCreated = (DateTime.Now - ticket.CreatedDate).TotalDays;
                            var daysSinceLastAction = ticket.LastActionDate.HasValue ? (DateTime.Now - ticket.LastActionDate.Value).TotalDays : daysSinceCreated;
                            var isExpired = daysSinceCreated > 3;
                            var isWarning = daysSinceCreated >= 2 && daysSinceCreated <= 3;
                            var statusClass = "";
                            var statusText = ticket.Status;
                            
                            if (ticket.Status == "Pending" || ticket.Status == "In Progress")
                            {
                                if (isExpired)
                                {
                                    statusClass = "bg-danger";
                                    statusText = $"{ticket.Status} (EXPIRED)";
                                }
                                else if (isWarning)
                                {
                                    statusClass = "bg-warning";
                                    statusText = $"{ticket.Status} (WARNING)";
                                }
                            }
                            
                            if (string.IsNullOrEmpty(statusClass))
                            {
                                if (ticket.Status == "Pending")
                                {
                                    statusClass = "bg-warning";
                                }
                                else if (ticket.Status == "In Progress")
                                {
                                    statusClass = "bg-info";
                                }
                                else if (ticket.Status == "Resolved")
                                {
                                    statusClass = "bg-success";
                                }
                                else if (ticket.Status == "Closed")
                                {
                                    statusClass = "bg-secondary";
                                }
                                else
                                {
                                    statusClass = "bg-primary";
                                }
                            }
                        }
                        <span class="badge @statusClass">@statusText</span>
                        @if (isExpired && (ticket.Status == "Pending" || ticket.Status == "In Progress"))
                        {
                            <br /><small class="text-danger">Overdue by @((int)daysSinceCreated - 3) day(s)</small>
                        }
                        else if (isWarning && (ticket.Status == "Pending" || ticket.Status == "In Progress"))
                        {
                            <br /><small class="text-warning">@((int)daysSinceCreated) day(s) old</small>
                        }
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(ticket.RelatedAssetName))
                        {
                            <span>@ticket.AssetType: @ticket.RelatedAssetName</span>
                        }
                        else
                        {
                            <span class="text-muted">N/A</span>
                        }
                    </td>
                    <td>
                        @ticket.CreatedDate.ToString("yyyy-MM-dd HH:mm")
                        @if (ticket.LastActionDate.HasValue && ticket.LastActionDate.Value != ticket.CreatedDate)
                        {
                            <br /><small class="text-muted">Updated: @ticket.LastActionDate.Value.ToString("yyyy-MM-dd HH:mm")</small>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@ticket.Id" class="btn btn-sm btn-info" title="View Details">
                            <i class="fas fa-eye"></i>
                        </a>
                        @{
                            var canEditTicket = isAdminOrITManager || isITSupportSupervisor || (isITSupport && ticket.AssignedToUserId != null);
                        }
                        @if (canEditTicket)
                        {
                            <a asp-action="Edit" asp-route-id="@ticket.Id" class="btn btn-sm btn-warning" title="Edit">
                                <i class="fas fa-edit"></i>
                            </a>
                        }
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="@(isAdminOrITManager ? (showAssignedTo ? 9 : 8) : (showAssignedTo ? 8 : 7))" class="text-center text-muted">No tickets found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
