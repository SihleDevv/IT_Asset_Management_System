@model IEnumerable<IT_Asset_Management_System.Models.ITSupportTicket>
@{
    ViewData["Title"] = "IT Support Tickets";
    var isAdminOrITManager = ViewBag.IsAdminOrITManager as bool? ?? false;
    var isITSupportSupervisor = ViewBag.IsITSupportSupervisor as bool? ?? false;
    var isITSupport = ViewBag.IsITSupport as bool? ?? false;
    var statusFilter = ViewBag.StatusFilter as string;
    var priorityFilter = ViewBag.PriorityFilter as string;
    var showAssignedTo = isAdminOrITManager || isITSupportSupervisor || isITSupport || !isAdminOrITManager;
}

@Html.AntiForgeryToken()

<div class="page-header mb-3">
    <h1>IT Support Tickets</h1>
    <p class="text-muted">Report and manage asset issues</p>
    @if (ViewBag.ExpiredTicketsCount != null && (int)ViewBag.ExpiredTicketsCount > 0)
    {
        <div class="alert alert-danger mt-2">
            <i class="fas fa-exclamation-triangle"></i> <strong>Warning:</strong> @ViewBag.ExpiredTicketsCount ticket(s) have exceeded the 3-day resolution deadline and require immediate attention.
        </div>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select name="status" class="form-select">
                    <option value="">All Statuses</option>
                    <option value="Pending" selected="@(statusFilter == "Pending")">Pending</option>
                    <option value="In Progress" selected="@(statusFilter == "In Progress")">In Progress</option>
                    <option value="Resolved" selected="@(statusFilter == "Resolved")">Resolved</option>
                    <option value="Closed" selected="@(statusFilter == "Closed")">Closed</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Priority</label>
                <select name="priority" class="form-select">
                    <option value="">All Priorities</option>
                    <option value="Low" selected="@(priorityFilter == "Low")">Low</option>
                    <option value="Medium" selected="@(priorityFilter == "Medium")">Medium</option>
                    <option value="High" selected="@(priorityFilter == "High")">High</option>
                    <option value="Critical" selected="@(priorityFilter == "Critical")">Critical</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary btn-sm me-2">Filter</button>
                <a asp-action="Index" class="btn btn-secondary btn-sm me-2">Clear</a>
                <div class="btn-group">
                    <button type="button" class="btn btn-success btn-sm dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-download"></i> Export
                    </button>
                    <ul class="dropdown-menu">
                        <li>
                            <a class="dropdown-item" asp-action="ExportToCsv" 
                               asp-route-status="@statusFilter" 
                               asp-route-priority="@priorityFilter">
                                <i class="fas fa-file-csv"></i> Export as CSV
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" asp-action="ExportToPdf" 
                               asp-route-status="@statusFilter" 
                               asp-route-priority="@priorityFilter">
                                <i class="fas fa-file-pdf"></i> Export as PDF
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
            <div class="col-md-3 d-flex align-items-end justify-content-end">
                <a asp-action="Create" class="btn btn-success">
                    <i class="fas fa-plus"></i> New Ticket
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Bulk Actions Bar -->
<div id="bulkActionsBar" class="card mb-3" style="display: none;">
    <div class="card-body py-2">
        <div class="d-flex justify-content-between align-items-center">
            <span class="text-muted">
                <span id="selectedCount">0</span> record(s) selected
            </span>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-warning btn-sm" id="bulkEditBtn" onclick="bulkEditTickets()">
                    <i class="fas fa-edit"></i> Edit Selected
                </button>
                <button type="button" class="btn btn-danger btn-sm" id="bulkDeleteBtn" onclick="bulkDeleteTickets()">
                    <i class="fas fa-trash"></i> Delete Selected
                </button>
            </div>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th style="width:50px">
                    <input type="checkbox" id="selectAllTickets" title="Select All" />
                </th>
                <th>Ticket ID</th>
                <th>Subject</th>
                @if (isAdminOrITManager)
                {
                    <th>Reported By</th>
                }
                @if (showAssignedTo)
                {
                    <th>Assigned To</th>
                }
                <th>Priority</th>
                <th>Status</th>
                <th>Created Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var ticket in Model)
            {
                <tr>
                    <td>
                        <input type="checkbox" class="ticket-checkbox" value="@ticket.Id" />
                    </td>
                    <td>#@ticket.Id</td>
                    <td>@ticket.Subject</td>
                    @if (isAdminOrITManager)
                    {
                        <td>@(ticket.ReportedByUser?.FullName ?? ticket.ReportedByUser?.Email ?? "N/A")</td>
                    }
                    @if (showAssignedTo)
                    {
                        <td>@(ticket.AssignedToUser?.FullName ?? ticket.AssignedToUser?.Email ?? "Unassigned")</td>
                    }
                    <td>
                        @if (ticket.Priority == "Critical")
                        {
                            <span class="badge bg-danger">@ticket.Priority</span>
                        }
                        else if (ticket.Priority == "High")
                        {
                            <span class="badge bg-warning">@ticket.Priority</span>
                        }
                        else if (ticket.Priority == "Medium")
                        {
                            <span class="badge bg-info">@ticket.Priority</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@ticket.Priority</span>
                        }
                    </td>
                    <td>
                        @{
                            var daysSinceCreated = (DateTime.Now - ticket.CreatedDate).TotalDays;
                            var daysSinceLastAction = ticket.LastActionDate.HasValue ? (DateTime.Now - ticket.LastActionDate.Value).TotalDays : daysSinceCreated;
                            var isExpired = daysSinceCreated > 3;
                            var isWarning = daysSinceCreated >= 2 && daysSinceCreated <= 3;
                            var statusClass = "";
                            var statusText = ticket.Status;
                            
                            if (ticket.Status == "Pending" || ticket.Status == "In Progress")
                            {
                                if (isExpired)
                                {
                                    statusClass = "bg-danger";
                                    statusText = $"{ticket.Status} (EXPIRED)";
                                }
                                else if (isWarning)
                                {
                                    statusClass = "bg-warning";
                                    statusText = $"{ticket.Status} (WARNING)";
                                }
                            }
                            
                            if (string.IsNullOrEmpty(statusClass))
                            {
                                if (ticket.Status == "Pending")
                                {
                                    statusClass = "bg-warning";
                                }
                                else if (ticket.Status == "In Progress")
                                {
                                    statusClass = "bg-info";
                                }
                                else if (ticket.Status == "Resolved")
                                {
                                    statusClass = "bg-success";
                                }
                                else if (ticket.Status == "Closed")
                                {
                                    statusClass = "bg-secondary";
                                }
                                else
                                {
                                    statusClass = "bg-primary";
                                }
                            }
                        }
                        <span class="badge @statusClass">@statusText</span>
                        @if (isExpired && (ticket.Status == "Pending" || ticket.Status == "In Progress"))
                        {
                            <br /><small class="text-danger">Overdue by @((int)daysSinceCreated - 3) day(s)</small>
                        }
                        else if (isWarning && (ticket.Status == "Pending" || ticket.Status == "In Progress"))
                        {
                            <br /><small class="text-warning">@((int)daysSinceCreated) day(s) old</small>
                        }
                    </td>
                    <td>
                        @ticket.CreatedDate.ToString("yyyy-MM-dd HH:mm")
                        @if (ticket.LastActionDate.HasValue && ticket.LastActionDate.Value != ticket.CreatedDate)
                        {
                            <br /><small class="text-muted">Updated: @ticket.LastActionDate.Value.ToString("yyyy-MM-dd HH:mm")</small>
                        }
                    </td>
                    <td>
                        <div class="d-flex gap-2 align-items-center">
                            <a asp-action="Details" asp-route-id="@ticket.Id" title="View Details" style="text-decoration: none; color: #0dcaf0; font-size: 1.1rem;">
                                <i class="fas fa-eye"></i>
                            </a>
                            @{
                                var canEditTicket = isAdminOrITManager || isITSupportSupervisor || (isITSupport && ticket.AssignedToUserId != null);
                            }
                            @if (canEditTicket)
                            {
                                <a asp-action="Edit" asp-route-id="@ticket.Id" title="Edit" style="text-decoration: none; color: #ffc107; font-size: 1.1rem;">
                                    <i class="fas fa-edit"></i>
                                </a>
                            }
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="@(isAdminOrITManager ? (showAssignedTo ? 9 : 8) : (showAssignedTo ? 8 : 7))" class="text-center text-muted">No tickets found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const selectAllCheckbox = document.getElementById('selectAllTickets');
        const ticketCheckboxes = document.querySelectorAll('.ticket-checkbox');
        const bulkActionsBar = document.getElementById('bulkActionsBar');
        const selectedCountSpan = document.getElementById('selectedCount');
        
        function updateBulkActionsBar() {
            const selectedCount = Array.from(ticketCheckboxes).filter(cb => cb.checked).length;
            if (selectedCount > 0) {
                bulkActionsBar.style.display = 'block';
                selectedCountSpan.textContent = selectedCount;
            } else {
                bulkActionsBar.style.display = 'none';
            }
        }
        
        if (selectAllCheckbox) {
            selectAllCheckbox.addEventListener('change', function() {
                ticketCheckboxes.forEach(checkbox => {
                    checkbox.checked = this.checked;
                });
                updateBulkActionsBar();
            });
        }
        
        // Update select all checkbox and bulk actions bar when individual checkboxes change
        ticketCheckboxes.forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                const allChecked = Array.from(ticketCheckboxes).every(cb => cb.checked);
                const someChecked = Array.from(ticketCheckboxes).some(cb => cb.checked);
                if (selectAllCheckbox) {
                    selectAllCheckbox.checked = allChecked;
                    selectAllCheckbox.indeterminate = someChecked && !allChecked;
                }
                updateBulkActionsBar();
            });
        });
    });
    
    function bulkEditTickets() {
        const selectedIds = Array.from(document.querySelectorAll('.ticket-checkbox:checked')).map(cb => cb.value);
        if (selectedIds.length === 0) {
            alert('Please select at least one record to edit.');
            return;
        }
        if (selectedIds.length === 1) {
            // Single record - go to edit page
            window.location.href = '@Url.Action("Edit", "ITSupport")?id=' + selectedIds[0];
        } else {
            // Multiple records - edit first one
            if (confirm(`You have selected ${selectedIds.length} records. Only one record can be edited at a time. Would you like to edit the first selected record?`)) {
                window.location.href = '@Url.Action("Edit", "ITSupport")?id=' + selectedIds[0];
            }
        }
    }
    
    function bulkDeleteTickets() {
        const selectedIds = Array.from(document.querySelectorAll('.ticket-checkbox:checked')).map(cb => cb.value);
        if (selectedIds.length === 0) {
            alert('Please select at least one record to delete.');
            return;
        }
        
        const count = selectedIds.length;
        if (confirm(`Are you sure you want to delete ${count} selected record(s)? This action cannot be undone.`)) {
            // Create form and submit
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '@Url.Action("BulkDelete", "ITSupport")';
            
            // Add anti-forgery token
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) {
                const tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '__RequestVerificationToken';
                tokenInput.value = token.value;
                form.appendChild(tokenInput);
            }
            
            // Add selected IDs
            selectedIds.forEach(id => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'ids';
                input.value = id;
                form.appendChild(input);
            });
            
            document.body.appendChild(form);
            form.submit();
        }
    }
</script>
