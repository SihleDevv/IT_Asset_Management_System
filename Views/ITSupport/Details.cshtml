@model IT_Asset_Management_System.Models.ITSupportTicket
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Support Ticket Details";
    var isAdminOrITManager = User.IsInRole("Admin") || User.IsInRole("IT Manager");
    var isITSupportSupervisor = ViewBag.IsITSupportSupervisor as bool? ?? false;
    var isITSupport = ViewBag.IsITSupport as bool? ?? false;
    var canEdit = ViewBag.CanEdit as bool? ?? false;
    var currentUser = await UserManager.GetUserAsync(User);
    var isTicketOwner = currentUser != null && Model.ReportedByUserId == currentUser.Id;
}

<div class="page-header mb-3">
    <h1>Support Ticket #@Model.Id</h1>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-3">
    <div class="card-header">
        <h5 class="mb-0">Ticket Information</h5>
    </div>
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-3"><strong>Subject:</strong></div>
            <div class="col-md-9">@Model.Subject</div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3"><strong>Status:</strong></div>
            <div class="col-md-9">
                @if (Model.Status == "Pending")
                {
                    <span class="badge bg-warning">@Model.Status</span>
                }
                else if (Model.Status == "In Progress")
                {
                    <span class="badge bg-warning">@Model.Status</span>
                }
                else if (Model.Status == "Resolved")
                {
                    <span class="badge bg-success">@Model.Status</span>
                }
                else
                {
                    <span class="badge bg-secondary">@Model.Status</span>
                }
                @if (Model.StatusChangedDate.HasValue)
                {
                    <br />
                    <small class="text-muted">
                        Changed on: @Model.StatusChangedDate.Value.ToString("yyyy-MM-dd HH:mm")
                        @if (Model.StatusChangedByUser != null)
                        {
                            <text> by @(Model.StatusChangedByUser.FullName ?? Model.StatusChangedByUser.Email)</text>
                        }
                    </small>
                }
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3"><strong>Priority:</strong></div>
            <div class="col-md-9">
                @if (Model.Priority == "Critical")
                {
                    <span class="badge bg-danger">@Model.Priority</span>
                }
                else if (Model.Priority == "High")
                {
                    <span class="badge bg-warning">@Model.Priority</span>
                }
                else if (Model.Priority == "Medium")
                {
                    <span class="badge bg-info">@Model.Priority</span>
                }
                else
                {
                    <span class="badge bg-secondary">@Model.Priority</span>
                }
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-3"><strong>Reported By:</strong></div>
            <div class="col-md-9">@(Model.ReportedByUser?.FullName ?? Model.ReportedByUser?.Email ?? "N/A")</div>
        </div>

        @if (isAdminOrITManager || isITSupportSupervisor || isITSupport)
        {
            <div class="row mb-3">
                <div class="col-md-3"><strong>Assigned To:</strong></div>
                <div class="col-md-9">@(Model.AssignedToUser?.FullName ?? Model.AssignedToUser?.Email ?? "Unassigned")</div>
            </div>
        }

        <div class="row mb-3">
            <div class="col-md-3"><strong>Created Date:</strong></div>
            <div class="col-md-9">@Model.CreatedDate.ToString("yyyy-MM-dd HH:mm")</div>
        </div>

        @if (Model.ResolvedDate.HasValue)
        {
            <div class="row mb-3">
                <div class="col-md-3"><strong>Resolved Date:</strong></div>
                <div class="col-md-9">@Model.ResolvedDate.Value.ToString("yyyy-MM-dd HH:mm")</div>
            </div>
        }
    </div>
</div>

<div class="card mb-3">
    <div class="card-header">
        <h5 class="mb-0">Issue Description</h5>
    </div>
    <div class="card-body">
        <p>@Model.Description</p>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.AdminResponse))
{
    <div class="card mb-3">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">Admin Response</h5>
        </div>
        <div class="card-body">
            <p>@Model.AdminResponse</p>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(Model.TechnicianNotes))
{
    <div class="card mb-3">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Technician Notes</h5>
        </div>
        <div class="card-body">
            <p>@Model.TechnicianNotes</p>
            @if (Model.TechnicianNotesDate.HasValue)
            {
                <small class="text-muted">Last updated: @Model.TechnicianNotesDate.Value.ToString("yyyy-MM-dd HH:mm")</small>
            }
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(Model.ResolutionNotes))
{
    <div class="card mb-3">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">Resolution Notes</h5>
        </div>
        <div class="card-body">
            <p>@Model.ResolutionNotes</p>
        </div>
    </div>
}

@if (Model.ReplacementRequested)
{
    <div class="card mb-3">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0"><i class="fas fa-exclamation-triangle"></i> Replacement Request</h5>
        </div>
        <div class="card-body">
            <p><strong>Reason:</strong> @Model.ReplacementReason</p>
            @if (Model.ReplacementApproved.HasValue)
            {
                if (Model.ReplacementApproved.Value)
                {
                    <p class="text-success"><strong>Status:</strong> Approved</p>
                }
                else
                {
                    <p class="text-danger"><strong>Status:</strong> Rejected</p>
                }
                @if (!string.IsNullOrEmpty(Model.ReplacementAdminResponse))
                {
                    <p><strong>Admin Response:</strong> @Model.ReplacementAdminResponse</p>
                }
            }
            else
            {
                <p class="text-warning"><strong>Status:</strong> Pending Admin Approval</p>
            }
        </div>
    </div>
}

<div class="mt-3">
    @if (canEdit)
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
            <i class="fas fa-edit"></i> Edit Ticket
        </a>
    }
    @if (isAdminOrITManager && Model.Status != "Closed")
    {
        <a asp-action="Close" asp-route-id="@Model.Id" class="btn btn-secondary" onclick="return confirm('Are you sure you want to close this ticket?');">
            <i class="fas fa-times"></i> Close Ticket
        </a>
    }
    @if (isTicketOwner && Model.Status != "Closed")
    {
        <a asp-action="FollowUp" asp-route-id="@Model.Id" class="btn btn-info">
            <i class="fas fa-comment"></i> Follow Up
        </a>
    }
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

@if (!string.IsNullOrEmpty(Model.UserFollowUp))
{
    <div class="card mb-3">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0"><i class="fas fa-comment"></i> User Follow Up</h5>
        </div>
        <div class="card-body">
            <p>@Model.UserFollowUp</p>
            @if (Model.FollowUpDate.HasValue)
            {
                <small class="text-muted">Posted on: @Model.FollowUpDate.Value.ToString("yyyy-MM-dd HH:mm")</small>
            }
        </div>
    </div>
}
